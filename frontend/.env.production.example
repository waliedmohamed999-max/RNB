# Public URL of the deployed Next.js app.
NEXT_PUBLIC_SITE_URL=https://example.com

# URL of the trusted Laravel bridge backend used by the dashboard API proxy.
NEXT_PUBLIC_LEGACY_BASE_URL=https://backend.example.com

# Optional Next.js build output directory. Keep `.next` unless your deployment needs another path.
NEXT_DIST_DIR=.next

# Optional local-only PHP binary used by scripts/ensure-laravel-server.cjs.
# Do not set this in container/cloud production unless that script is intentionally used.
PHP_BIN=/usr/local/bin/php

# Database connection string placeholder for deployments that add a direct DB layer.
# The current dashboard frontend does not connect directly to the database.
DATABASE_URL=mysql://user:password@db:3306/labayh

# Strong random value reserved for future Next-side auth/session signing.
# The current implementation validates the Laravel bridge session.
AUTH_SECRET=replace-with-at-least-32-random-characters

# Comma-separated trusted origins for future CORS expansion.
TRUSTED_ORIGINS=https://example.com,https://backend.example.com

# Required in production for the local/emergency admin login fallback to work at all.
# If ADMIN_PASSWORD is not set, local admin login is disabled entirely — no default
# password is accepted, even if ADMIN_EMAIL matches. Set both to a real, unique, strong
# password before deploying if this fallback login is needed.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-unique-password
