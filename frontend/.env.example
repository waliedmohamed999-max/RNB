NEXT_PUBLIC_LEGACY_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_DIST_DIR=.next
PHP_BIN=C:\xampp\php\php.exe

# Optional local admin login override (dev only). If unset, the local admin login accepts
# admin@labayh.local with password "password" or "strong-password" for convenience.
# In production these dev fallback passwords are disabled — see .env.production.example.
ADMIN_EMAIL=admin@labayh.local
ADMIN_PASSWORD=
