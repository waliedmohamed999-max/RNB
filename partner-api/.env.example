PORT=4100
DATABASE_URL=postgres://postgres:postgres@localhost:5432/labayh_partners
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars
# Only set this to "true" for local development if you intentionally want to run
# without a strong JWT_SECRET. Never set this in production - the server will
# refuse to start if it is "true" and NODE_ENV=production.
# ALLOW_WEAK_JWT_SECRET=true
JWT_EXPIRES_IN=8h
# Must point outside any directory a web server (e.g. Apache/XAMPP htdocs) could
# serve directly. If unset, defaults to a directory under the OS temp folder.
UPLOAD_DIR=/var/data/partner-api-uploads
FRONTEND_ORIGIN=http://localhost:3000
ADMIN_EMAIL=admin@labayh.local
ADMIN_PASSWORD=replace-with-a-strong-admin-password
